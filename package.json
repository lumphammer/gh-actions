{
  "name": "@lumphammer/gh-actions",
  "scripts": {
    "lint:check": "eslint .github",
    "build-actions": "./scripts/build-actions.sh",
    "typecheck": "tsc --noEmit",
    "postinstall": "pnpm run build-actions"
  },
  "type": "module",
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@lumphammer/shared-fvtt-bits": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "chalk": "^5.6.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react": "^1.1.7",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.2",
      "onFail": "download"
    }
  },
  "dependencies": {
    "fs-extra": "^11.3.5"
  }
}
